datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RIDER)
  createdAt DateTime @default(now())

  driverProfile Driver?
  rides         Ride[]  @relation("RiderRides")
}

model Driver {
  id          Int          @id @default(autoincrement())
  userId      Int          @unique
  vehicleType String
  rating        Float        @default(5.0)
  status        DriverStatus @default(OFFLINE)
  totalEarnings Float        @default(0.0)
  walletBalance Float        @default(0.0)
  createdAt     DateTime     @default(now())

  user      User             @relation(fields: [userId], references: [id])
  rides     Ride[]           @relation("DriverRides")
  locations DriverLocation[]
}

model Location {
  id          Int      @id @default(autoincrement())
  placeId     String?  @unique
  displayName String
  latitude    Float
  longitude   Float
  name        String?
  road        String?
  city        String?
  postcode    String?
  country     String?
  countryCode String?
  createdAt   DateTime @default(now())

  ridesAsPickup      Ride[] @relation("PickupLocation")
  ridesAsDestination Ride[] @relation("DestinationLocation")
}

model Ride {
  id                    Int        @id @default(autoincrement())
  riderId               Int
  driverId              Int?
  pickupLocationId      Int
  destinationLocationId Int
  price                 Float?
  distanceKm            Float?
  status                RideStatus @default(REQUESTED)
  createdAt             DateTime   @default(now())

  rider               User     @relation("RiderRides", fields: [riderId], references: [id])
  driver              Driver?  @relation("DriverRides", fields: [driverId], references: [id])
  pickupLocation      Location @relation("PickupLocation", fields: [pickupLocationId], references: [id])
  destinationLocation Location @relation("DestinationLocation", fields: [destinationLocationId], references: [id])
}

model DriverLocation {
  id        Int      @id @default(autoincrement())
  driverId  Int
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id])
}

enum Role {
  RIDER
  DRIVER
  ADMIN
}

enum DriverStatus {
  ONLINE
  OFFLINE
  ON_RIDE
}

enum RideStatus {
  REQUESTED
  MATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
